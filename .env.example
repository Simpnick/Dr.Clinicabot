# Configurações do Servidor
PORT=3000

# Telefone do Médico (usar DDI + DDD + Número apenas números, ex: 5511999999999)
DOCTOR_PHONE=5511999999999

# Credenciais da API de IA (Gemini ou OpenAI)
GEMINI_API_KEY=sua_chave_do_gemini_aqui

# Credenciais do Google OAuth 2.0 (Obtidas no Google Cloud Console)
GOOGLE_CLIENT_ID=seu_client_id_oauth_aqui.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=seu_client_secret_oauth_aqui
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# IDs dos Recursos do Google Workspace (O ID da Planilha pode ser encontrado na URL da planilha criada)
GOOGLE_SPREADSHEET_ID=id_da_sua_planilha_sheets_aqui
GOOGLE_CALENDAR_ID=primary # ou o e-mail da agenda do médico caso secundária

# Configurações do WhatsApp (API Oficial Cloud)
WHATSAPP_PHONE_NUMBER_ID=seu_phone_number_id_aqui
WHATSAPP_ACCESS_TOKEN=seu_access_token_aqui
WHATSAPP_VERIFY_TOKEN=sua_verify_token_definida_por_voce_aqui
WHATSAPP_SIMULATION_MODE=true

